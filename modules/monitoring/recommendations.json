          "editorMode": "code",
          "expr": "process_max_fds{job=\"recommendations\"}",
          "legendFormat": "Max FDs limit",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "File Descriptors",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fastapi", "prometheus", "python", "recommendations"],
